# =============================================================================
# LAR System — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# On Azure App Service, set these as Application Settings instead of a .env file.
# =============================================================================

# Application Environment (development | testing | production)
APP_ENV=production

# =============================================================================
# Primary Database (all verticals except Services API)
# =============================================================================
DB_HOSTNAME=localhost
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_DATABASE=your_db_name

# =============================================================================
# Secondary Database (Services API / LAR webservices)
# =============================================================================
DB2_HOSTNAME=localhost
DB2_USERNAME=your_db2_username
DB2_PASSWORD=your_db2_password
DB2_DATABASE=lar_webservices

# =============================================================================
# API Credentials — TBO Flights
# =============================================================================
TBO_USERNAME=your_tbo_username
TBO_PASSWORD=your_tbo_password
TBO_API_KEY=your_tbo_api_key

# =============================================================================
# API Credentials — PROVAB Hotels
# =============================================================================
PROVAB_API_KEY=your_provab_key
PROVAB_USERNAME=your_provab_username

# =============================================================================
# Payment Gateway — PayU
# =============================================================================
PAYU_MERCHANT_KEY=your_merchant_key
PAYU_MERCHANT_SALT=your_merchant_salt
PAYU_MERCHANT_ID=your_merchant_id
PAYU_MODE=live

# =============================================================================
# Payment Gateway — PayPal
# =============================================================================
PAYPAL_MODE=live
PAYPAL_CLIENT_ID=your_client_id
PAYPAL_SECRET=your_secret

# =============================================================================
# Email / SMTP
# =============================================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_smtp_password

# =============================================================================
# Application Security
# =============================================================================
SESSION_KEY=replace_with_32_random_chars_here_xx
ENCRYPTION_KEY=replace_with_32_random_chars_here_xx
